# ATS Recrutement - Variables d'environnement
# Copiez ce fichier en .env et renseignez les valeurs

# Base de données MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=votre_mot_de_passe
MYSQL_DATABASE=ats_recrutement

# Sécurité JWT (à changer en production)
SECRET_KEY=votre-secret-key-tres-long-et-aleatoire

# Optionnel
DEBUG=false
UPLOAD_DIR=uploads/cv
MAX_CV_SIZE_MB=5
ALLOWED_CV_EXTENSIONS=pdf,doc,docx
